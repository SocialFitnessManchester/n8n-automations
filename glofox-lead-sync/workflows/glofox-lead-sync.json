        "text": "=:white_check_mark: *Glofox initial sync \u2014 {{ $('Pick Studio').first().json.studio_name }}*\nPushed *{{ $json.total }}* records to GoHighLevel.\nBy status: {{ $json.by_status }}\nBy GHL type: {{ $json.by_type }}",
        "otherOptions": {}
      },
