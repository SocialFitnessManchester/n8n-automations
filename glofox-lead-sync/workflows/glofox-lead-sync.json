      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "name": "Get All Leads (paged)",
      "position": [
        448,
        0
      ],
      "id": "485b43c3-bc4e-4185-8020-ceb0eae3c87e"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst all = [];\nfor (const it of items) {\n  const j = it.json;\n  if (Array.isArray(j.data)) all.push(...j.data);\n  else if (j && (j._id || j.lead_status)) all.push(j);\n}\nconst isCustomer = s => s === 'MEMBER' || s === 'TRIAL';\nreturn all.map(l => ({ json: {\n  first_name: l.first_name || '', last_name: l.last_name || '',\n  email: l.email || l.contact_email || l.account_email || '',\n  phone: l.phone || '', lead_status: l.lead_status || '',\n  ghl_type: isCustomer(l.lead_status) ? 'customer' : 'lead', created: l.created\n}}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "name": "Flatten Leads",
      "position": [
        672,
        -96
      ],
      "id": "55c868fc-ef14-4125-853b-b67470733012"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://services.leadconnectorhq.com/contacts/upsert",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $('Pick Studio').first().json.ghl_pit }}"
            },
            {
              "name": "Version",
              "value": "2021-07-28"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"locationId\": \"{{ $('Pick Studio').first().json.ghl_location }}\",\n  \"email\": \"{{ $json.email }}\",\n  \"firstName\": \"{{ $json.first_name }}\",\n  \"lastName\": \"{{ $json.last_name }}\",\n  \"phone\": \"{{ $json.phone }}\",\n  \"type\": \"{{ $json.ghl_type }}\",\n  \"source\": \"Glofox initial sync\",\n  \"tags\": [\"glofox-initial-sync\"]\n}",
        "options": {
          "batching": {
            "batch": {
              "batchSize": 8,
              "batchInterval": 2000
            }
          }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "name": "GHL: Upsert Contact",
      "position": [
        880,
        -96
      ],
      "id": "cb1f7823-4ae5-4959-b3c2-96a329d5c1d9",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet total=0; const byStatus={}; const byType={};\nfor (const it of items) {\n  const data = Array.isArray(it.json.data) ? it.json.data : (it.json && it.json._id ? [it.json] : []);\n  total += data.length;\n  for (const l of data) {\n    byStatus[l.lead_status]=(byStatus[l.lead_status]||0)+1;\n    const t=(l.lead_status==='MEMBER'||l.lead_status==='TRIAL')?'customer':'lead';\n    byType[t]=(byType[t]||0)+1;\n  }\n}\nreturn [{ json: { total, by_status: JSON.stringify(byStatus), by_type: JSON.stringify(byType) } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "name": "Sync Summary",
      "position": [
        672,
        144
      ],
      "id": "1de0d2b6-ce8c-4019-a395-c50379c98bb0"
    },
    {
