          "value": "gid=0",
          "mode": "list",
          "cachedResultName": "Sheet1"
        },
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "Branch ID",
              "lookupValue": "={{ $('Extract Branch ID').item.json.location_id }}"
            }
          ]
        },
        "options": {}
      },
      "credentials": {
        "googleApi": {
          "id": "PvDoggN1HExofTc3",
          "name": "Google Service Account account"
        }
      },
      "notes": "Looks up the studio name by Branch ID. onError=continue + alwaysOutputData so the alert still fires when there's no match / no branch id.",
      "onError": "continueRegularOutput",
      "alwaysOutputData": true
    },
    {
      "id": "eh-limit",
      "name": "One Alert Only",
      "type": "n8n-nodes-base.limit",
      "typeVersion": 1,
      "position": [
        800,
