    {
      "id": "eh-get-exec",
      "name": "Get Failed Execution",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        220,
        0
      ],
      "parameters": {
        "url": "=https://automation.social-fitness.com/api/v1/executions/{{ $('Error Trigger').item.json.execution.id }}?includeData=true",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "options": {}
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "iITPBQHeXXmt7oTS",
          "name": "n8n API (self)"
        }
      },
      "notes": "Pulls the failed execution's data via the n8n API to recover the original webhook payload (Branch ID). onError=continue so the alert still fires if this fails.",
      "onError": "continueRegularOutput",
      "alwaysOutputData": true
    },
    {
      "id": "eh-extract",
      "name": "Extract Branch ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        0
      ],
      "parameters": {
        "jsCode": "const ex = $input.first().json;\nlet data = ex.data;\nif (typeof data === 'string') { try { data = JSON.parse(data); } catch (e) { data = {}; } }\nlet locationId = null;\ntry {\n  const runData = (data && data.resultData && data.resultData.runData) || {};\n  const wh = runData['Glofox Webhook'];\n  const j = wh && wh[0] && wh[0].data && wh[0].data.main && wh[0].data.main[0] && wh[0].data.main[0][0] && wh[0].data.main[0][0].json;\n  const body = j && j.body;\n  locationId = (body && body.Metadata && body.Metadata.location_id) || null;\n} catch (e) { locationId = null; }\nreturn [{ json: { location_id: locationId } }];"
      },
      "notes": "Pulls metadata.location_id (Branch ID) out of the failed execution's webhook payload. Handles string-or-object data and missing paths -> null."
    },
    {
      "id": "eh-lookup",
      "name": "Lookup Studio",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [
        660,
        0
      ],
      "parameters": {
        "authentication": "serviceAccount",
        "documentId": {
          "__rl": true,
